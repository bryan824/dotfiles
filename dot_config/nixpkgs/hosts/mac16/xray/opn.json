{
  "log": {
    "loglevel": "debug",
    "access": "",
    "error": ""
  },
  "dns": {
    "servers": [
      "127.0.0.1",
      {
        "address": "https+local://223.5.5.5/dns-query",
        "domains": [
          "geosite:bilibili",
          "geosite:sina",
          "domain:sinaimg.cn",
          "domain:weibo.cn",
          "domain:f.video.weibocdn.com"
        ]
      },
      "https+local://1.1.1.1/dns-query"
    ],
    "clientIp": "1.2.3.4",
    "tag": "dns-in"
  },
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "balancers": [
      {
        "tag": "proxy",
        "selector": ["vless"],
        "strategy": "latency",
        "interval": 60,
        "totalMeasures": 2,
        "delay": 1,
        "timeout": 6,
        "tolerance": 300,
        "probeTarget": "tls:www.bing.com:443",
        "probeContent": "HEAD / HTTP/1.1\r\n\r\n"
      }
    ],
    "rules": [
      {
        "type": "field",
        "domain": ["domain:gate.hockeyapp.net", "geosite:category-ads-all"],
        "outboundTag": "block"
      },
      {
        "type": "field",
        "outboundTag": "vmess",
        "protocol": ["bittorrent"]
      },
      {
        "type": "field",
        "outboundTag": "vmess",
        "domain": [
          "domain:ipinfo.io",
          "domain:mozilla.org",
          "domain:speed.cloudflare.com",
          "geosite:youtube",
          "geosite:google",
          "geosite:reddit",
          "domain:t66y.com"
        ]
      },
      {
        "type": "field",
        "outboundTag": "direct",
        "ip": [
          "geoip:cn",
          "geoip:private",
          "223.5.5.5/32",
          "119.29.29.29/32",
          "180.76.76.76/32",
          "114.114.114.114/32",
          "1.1.1.1/32",
          "1.0.0.1/32",
          "8.8.8.8/32",
          "8.8.4.4/32"
        ]
      },
      {
        "type": "field",
        "outboundTag": "direct",
        "domain": [
          "domain:adguard.com",
          "domain:verizon.com",
          "domain:meetup.com",
          "domain:startpage.com",
          "domain:googletagmanager.com",
          "domain:teleosaurs.xyz",
          "domain:kintohub.com",
          "keyword:zeit",
          "full:ip.istatmenus.app",
          "verstandtime.ghg.com",
          "domain:thepiratebay.org"
        ]
      },
      {
        "type": "field",
        "network": "udp,tcp",
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "ip": ["0.0.0.0/0", "::/0"],
        "outboundTag": "direct"
      }
    ]
  },
  "inbounds": [
    {
      "port": 1081,
      "protocol": "dokodemo-door",
      "settings": {
        "network": "tcp,udp",
        "followRedirect": true
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "dns",
      "tag": "dns-out"
    },
    {
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "198.148.111.87",
            "port": 443,
            "users": [
              {
                "id": "67F85AD3-A521-458C-A5B3-2DDB1B07A8F4",
                "flow": "xtls-rprx-direct",
                "encryption": "none",
                "level": 0
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "sockopt": {
          "mark": 255
        },
        "security": "xtls",
        "xtlsSettings": {
          "serverName": "v2.bryantu.me"
        }
